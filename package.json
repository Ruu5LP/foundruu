{
  "name": "foundruu",
  "version": "0.7.1",
  "description": "FoundRuu CLI - AI開発を標準化するためのプラットフォームCLI",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "foundruu": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:action": "esbuild src/cli.ts --bundle --platform=node --target=node22 --format=cjs --outfile=action/index.cjs --banner:js=\"// Generated by npm run build:action — do not edit. Bundled entrypoint for the GitHub Action.\"",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "handlebars": "^4.7.8",
    "picocolors": "^1.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "cli",
    "ai",
    "scaffold",
    "workflow",
    "doctor",
    "foundruu"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ruu5LP/foundruu.git"
  },
  "author": "Ruu5LP"
}
