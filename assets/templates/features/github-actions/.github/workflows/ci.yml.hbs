name: CI

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]

jobs:
  ci:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v7

{{#eq language "typescript"}}
      - uses: actions/setup-node@v6
        with:
          node-version: '24'
          cache: 'npm'

      - run: npm ci

      - run: npm run typecheck
{{#if (hasFeature "eslint")}}
      - run: npm run lint
{{/if}}
{{#if (hasFeature "vitest")}}
      - run: npm test
{{/if}}
      - run: npm run build
{{/eq}}

{{#eq language "python"}}
      - uses: actions/setup-python@v6
        with:
          python-version: '3.14'

      - run: pip install -r requirements-dev.txt
      - run: ruff check .
      - run: ruff format --check .
      - run: mypy
      - run: python -m pytest
{{/eq}}

{{#eq language "laravel"}}
      - uses: shivammathur/setup-php@v2
        with:
          php-version: '8.5'

      - run: composer install --no-interaction
      - run: cp .env.example .env && php artisan key:generate
      - run: php artisan test
{{/eq}}

{{#eq language "nextjs"}}
      - uses: actions/setup-node@v6
        with:
          node-version: '24'
          cache: 'npm'

      - run: npm ci
{{#if (hasFeature "eslint")}}
      - run: npm run lint
{{/if}}
{{#if (hasFeature "vitest")}}
      - run: npm test
{{/if}}
      - run: npm run build
{{/eq}}

{{#eq language "nuxt"}}
      - uses: actions/setup-node@v6
        with:
          node-version: '24'
          cache: 'npm'

      - run: npm ci
{{#if (hasFeature "eslint")}}
      - run: npm run lint
{{/if}}
{{#if (hasFeature "vitest")}}
      - run: npm test
{{/if}}
      - run: npm run build
{{/eq}}
