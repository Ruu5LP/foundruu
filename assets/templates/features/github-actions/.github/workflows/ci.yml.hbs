name: CI

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]

jobs:
  ci:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v7

{{#eq language "typescript"}}
      - uses: actions/setup-node@v6
        with:
          node-version: '24'
          cache: 'npm'

      - run: npm ci

      # 既知の脆弱性がある依存を警告表示する（上流の勧告で CI は落とさない。放置しないこと）
      - run: npm audit --audit-level=high
        continue-on-error: true

      - run: npm run typecheck
{{#if (hasFeature "eslint")}}
      - run: npm run lint
{{/if}}
{{#if (hasFeature "vitest")}}
      - run: npm test
{{/if}}
      - run: npm run build
{{/eq}}

{{#eq language "python"}}
      - uses: actions/setup-python@v6
        with:
          python-version: '3.14'

      - run: pip install -r requirements-dev.txt

      # 既知の脆弱性がある依存を警告表示する（上流の勧告で CI は落とさない。放置しないこと）
      - run: pip-audit
        continue-on-error: true

      - run: ruff check .
      - run: ruff format --check .
      - run: mypy
      - run: python -m pytest
{{/eq}}

{{#eq language "laravel"}}
      - uses: shivammathur/setup-php@v2
        with:
          php-version: '8.5'

      - run: composer install --no-interaction

      # 既知の脆弱性がある依存を警告表示する（上流の勧告で CI は落とさない。放置しないこと）
      - run: composer audit
        continue-on-error: true

      # 整形（Pint）と静的解析（PHPStan/Larastan level 8）を CI で担保する
      - run: composer lint
      - run: composer analyse

      - run: cp .env.example .env && php artisan key:generate
      - run: php artisan test
{{/eq}}

{{#eq language "nextjs"}}
      - uses: actions/setup-node@v6
        with:
          node-version: '24'
          cache: 'npm'

      - run: npm ci

      # 既知の脆弱性がある依存を警告表示する（上流の勧告で CI は落とさない。放置しないこと）
      - run: npm audit --audit-level=high
        continue-on-error: true

      - run: npm run typecheck
{{#if (hasFeature "eslint")}}
      - run: npm run lint
{{/if}}
{{#if (hasFeature "vitest")}}
      - run: npm test
{{/if}}
      - run: npm run build
{{/eq}}

{{#eq language "nuxt"}}
      - uses: actions/setup-node@v6
        with:
          node-version: '24'
          cache: 'npm'

      - run: npm ci

      # 既知の脆弱性がある依存を警告表示する（上流の勧告で CI は落とさない。放置しないこと）
      - run: npm audit --audit-level=high
        continue-on-error: true

      - run: npm run typecheck
      # Nuxt は @nuxt/eslint を言語層で同梱しているため lint は常に実行する
      - run: npm run lint
{{#if (hasFeature "vitest")}}
      - run: npm test
{{/if}}
      - run: npm run build
{{/eq}}
